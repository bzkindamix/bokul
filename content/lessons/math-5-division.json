  "teachScripts": {
    "s1-concrete": [
      { "say": "Komutan, bölme dediğin şey aslında ADİL PAYLAŞTIRMAKTIR. Göstereyim." },
      { "deal": { "total": 12, "groups": 3 } },
      { "ask": "12 kutuyu 3 takıma paylaştırdık. Her takıma kaç kutu düştü?", "expect": 4 },
      { "say": "Aynen öyle: 12 ÷ 3 = 4. Bölme, eşit paylaştırmanın kısa yoludur." }
    ],
    "s1-pictorial": [
      { "say": "Sayılar büyüyünce kutu saymak yavaş kalır. Basamaklara bakarız: onluklar ve birlikler." },
      { "pv": { "number": 36, "divisor": 3 } },
      { "ask": "36'da 3 onluk var. 3 onluğu 3 gruba paylaştırırsak her gruba kaç ONLUK düşer?", "expect": 1 },
      { "ask": "Şimdi birlikler: 6 birlik ÷ 3 = ?", "expect": 2 },
      { "say": "Her gruba 1 onluk + 2 birlik = 12. Yani 36 ÷ 3 = 12. Önce büyük basamak, sonra küçük!" }
    ],
    "s1-abstract": [
      { "say": "Şimdi bunu kâğıt üzerindeki haliyle yapalım: UZUN BÖLME. Ben yanındayım, adım adım gidiyoruz." },
      { "guided": { "dividend": 84, "divisor": 4 } }
    ],
    "s2-brief": [
      { "say": "İki basamaklı bölünenlerde sır şu: soldan başla, sırayla in. Aynı 5 adım: SEÇ, TAHMİN, ÇARP, ÇIKAR, İNDİR." },
      { "guided": { "dividend": 96, "divisor": 6 } },
      { "say": "Gördün mü? Kalan her turda bölenden küçük kaldı. Kale kuralı asla bozulmaz!" }
    ],
    "s3-brief": [
      { "say": "Üç basamakta yeni bir durum var Komutan: ilk basamak bölenden KÜÇÜKSE iki basamak birden alırız. İzle." },
      { "guided": { "dividend": 435, "divisor": 5 } },
      { "say": "4, 5'ten küçüktü — o yüzden 43'ü aldık. Kural bu: yetmezse bir basamak daha!" }
    ],
    "s4-brief": [
      { "say": "Dört basamak! Gözünü korkutmasın — aynı 5 adım, sadece daha uzun yürüyüş. Efsane soruyla başlıyoruz." },
      { "guided": { "dividend": 4872, "divisor": 6 } },
      { "say": "4872 ÷ 6 = 812. Artık dört basamaklı kaleleri de açabilirsin Komutan!" }
    ]
  },


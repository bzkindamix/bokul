  "teachScripts": {
    "nota-brief": [
      {
        "say": "Gizli cephe açıldı Komutan — çünkü sen MÜZİĞİ seçtin! Müziğin alfabesi yedi notadır: Do, Re, Mi, Fa, Sol, La, Si. Sonra tekrar Do'ya döner, bu bir 'oktav'dır."
      },
      {
        "say": "Notalar bir merdiven gibidir: Do en altta, yukarı çıktıkça ses incelir. Portede (beş çizgi) notalar farklı yerlerde durur; yeri, sesin kalınlığını gösterir."
      },
      {
        "say": "Bir de RİTİM var: notaların ne kadar sürdüğü. Uzun notalar, kısa notalar... Ritim, müziğin kalp atışıdır!"
      }
    ],
    "enstruman-brief": [
      {
        "say": "İkinci brifing: enstrüman AİLELERİ. Telliler (gitar, keman), üflemeliler (flüt, trompet), vurmalılar (davul, marimba) ve tuşlular (piyano)."
      },
      {
        "say": "Piyano hem tuşlu hem tellidir — tuşa basınca içerideki çekiç TELE vurur! Keman yayla, gitar parmakla çalınır. Her ailenin kendine has bir sesi vardır."
      },
      {
        "say": "Bir orkestrada bu aileler birlikte çalar. Şef hepsini yönetir — tıpkı bir komutan gibi! Şimdi sıra sende."
      }
    ]
  },

  "teachScripts": {
    "add-brief": [
      { "say": "Brifing Komutan! TOPLAMA, iki grubu birleştirmektir. Bak şimdi: elmaları sayalım." },
      { "objects": { "a": 3, "b": 2, "emoji": "🍎", "op": "+" } },
      { "say": "3 elma ile 2 elmayı birleştirdik: 5 etti! Artı işareti (+) 'birleştir' demektir." },
      { "ask": "4 + 3 kaç eder?", "expect": 7 },
      { "say": "Aynen! Toplama bu kadar basit. Şimdi sahaya!" }
    ],
    "sub-brief": [
      { "say": "ÇIKARMA, bir gruptan koparıp almaktır. Kurabiyelerle görelim." },
      { "objects": { "a": 7, "b": 3, "emoji": "🍪", "op": "-" } },
      { "say": "7 kurabiye vardı, 3'ünü yedik... 4 kaldı! Eksi işareti (−) 'geriye ne kaldı' diye sorar." },
      { "ask": "9 − 4 kaç eder?", "expect": 5 },
      { "say": "Harika! Kalanı buldun. Çıkarma da cephaneliğe girdi." }
    ],
    "mul-brief": [
      { "say": "ÇARPMA bir kestirme yoldur Komutan! 'Kaç grup, her grupta kaç tane' demektir. Yıldızlara bak:" },
      { "groups": { "n": 4, "per": 3, "emoji": "⭐" } },
      { "say": "4 grup, her grupta 3 yıldız = 12. Yani 4 × 3 = 12. Tek tek toplamak yerine çarpıyoruz!" },
      { "ask": "2 grup, her grupta 3 tane. 2 × 3 kaç eder?", "expect": 6 },
      { "say": "İşte bu! Çarpım tablosu en güçlü silahındır." }
    ],
    "share-brief": [
      { "say": "Şimdi sıra BÖLMEDE. Bölme, ADİL PAYLAŞTIRMAKTIR. 12 kutuyu 3 takıma eşit dağıtalım, bakalım her takıma kaç düşecek." },
      { "deal": { "total": 12, "groups": 3 } },
      { "ask": "12'yi 3'e paylaştırdık. Her takıma kaç kutu düştü?", "expect": 4 },
      { "say": "Aynen! 12 ÷ 3 = 4. Bölme, çarpmanın tersidir: 3 × 4 = 12, 12 ÷ 3 = 4. İkiz kardeş gibiler!" }
    ],
    "long-brief": [
      { "say": "En büyük harekât Komutan: UZUN BÖLME! Büyük sayıları bölmek için adım adım gideriz: seç, tahmin et, çarp, çıkar, indir. Ben yanındayım." },
      { "guided": { "dividend": 84, "divisor": 4 } },
      { "say": "Gördün mü? Büyük sayı bile adım adım teslim oldu. Artık dört basamaklı kaleleri açabilirsin!" }
    ]
  },


  "teachScripts": {
    "temel-brief": [
      {
        "say": "Gizli cephe açıldı Komutan — çünkü sen SPORU seçtin! Sporun ilk kuralı: ısınmadan başlama. Kaslar soğukken zorlanırsa incinir. Önce hafif koşu, esneme; sonra oyun!"
      },
      {
        "say": "İkinci kural: FAIR PLAY (dürüst oyun). Kazanmak güzeldir ama HİLE yapmadan, rakibe saygıyla oynamak asıl kahramanlıktır. Yenilince de tebrik edersin — gerçek komutan böyle olur."
      },
      {
        "say": "Ve unutma: su iç! Spor yaparken terlersin, su kaybedersin. Susuz komutan yorulur. Şimdi sahaya, asker!"
      }
    ],
    "brans-brief": [
      {
        "say": "İkinci brifing: spor BRANŞLARI. Bazıları TAKIM sporudur — futbol, basketbol, voleybol. Arkadaşlarınla birlikte, pas vererek oynarsın."
      },
      {
        "say": "Bazıları BİREYSEL sporudur — yüzme, koşu, jimnastik, tenis. Kendi gücünle yarışırsın. İkisi de seni güçlendirir!"
      },
      {
        "say": "Spor sadece kas değildir: düzenli spor kalbini güçlendirir, uykunu düzeltir, moralini yükseltir. Sağlıklı beslenme + spor + uyku = süper komutan üçlüsü. Hadi göster kendini!"
      }
    ]
  },

  "teachScripts": {
    "eng-brief": [
      { "say": "Yeni cephe Komutan: İNGİLİZCE! Dünyanın en çok konuşulan ortak dili. Bu dili bilen, tüm dünyayla konuşabilir. Süper güç değil de nedir?" },
      { "say": "Korkma, adım adım gideceğiz. Önce selamlaşma: 'Hello' (Merhaba), 'Goodbye' (Hoşça kal), 'Thank you' (Teşekkürler). Bunlar sihirli kelimeler!" },
      { "say": "Kural şu: her gün birkaç kelime = kısa sürede koca bir hazine. Bulanık İngilizce bilmez, o yüzden bu cephe onun kâbusu. Hücum!" }
    ],
    "eng-brief2": [
      { "say": "İkinci brifing Komutan: artık kelimeleri birleştirip CÜMLE kuracağız. 'I am happy' (Ben mutluyum), 'This is a cat' (Bu bir kedi)." },
      { "say": "Renkler, sayılar, aile... hepsi cephanemiz. Ne kadar çok kelime, o kadar güçlü asker. Bulanık'ın sisini İngilizceyle dağıtacağız!" }
    ]
  },


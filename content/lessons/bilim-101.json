  "teachScripts": {
    "uzay-brief": [
      {
        "say": "Gizli cephe açıldı Komutan — çünkü sen BİLİMİ seçtin! Yaşadığımız yer DÜNYA, bir gezegen. Güneş'in etrafında dönen 8 gezegen var: Merkür, Venüs, Dünya, Mars, Jüpiter, Satürn, Uranüs, Neptün."
      },
      {
        "say": "GÜNEŞ bir yıldızdır — dev bir ateş topu! Bize ışık ve ısı verir. AY ise Dünya'nın uydusudur, kendi ışığı yoktur; Güneş'in ışığını yansıtır."
      },
      {
        "say": "Gece-gündüz, Dünya kendi ekseninde döndüğü için olur. Güneş'e bakan taraf gündüz, arkada kalan gece! Sen de bir galaksi kâşifisin — hadi keşfet!"
      }
    ],
    "madde-brief": [
      {
        "say": "İkinci brifing: MADDENİN HALLERİ. Her şey üç halde olabilir: KATI (buz, taş), SIVI (su, süt), GAZ (hava, buhar). Isı bunları birbirine çevirir!"
      },
      {
        "say": "Buzu ısıtırsan SU olur (erir), suyu daha da ısıtırsan BUHAR olur (buharlaşır). Soğutursan tersine döner. Su, tabiatın sihirbazı!"
      },
      {
        "say": "Bilim GÖZLEM ve DENEY ile ilerler: merak et, tahmin et, dene, gör. Bir bilim insanı gibi soru sor: 'Acaba neden?' İşte gerçek keşif budur!"
      }
    ]
  },
